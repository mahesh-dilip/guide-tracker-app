# --- Client environment variables (Vite) ---
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# Base URL of the backend API.
# - Leave UNSET in local development: the client falls back to the relative
#   "/api" path (see client/src/services/api.js) so the Vite dev proxy can
#   forward requests to the local server.
# - In production (e.g. Vercel), set this to your deployed backend origin
#   WITHOUT a trailing "/api" — the client appends "/api" itself.
#     e.g. VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=
