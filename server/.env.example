# --- Server environment variables ---
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Port the Express API listens on (defaults to 8000 if unset)
PORT=8000

# Google Gemini API key — used by services/geminiService.js for guide
# structuring and the in-guide Q&A chatbot. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ElevenLabs API key — used by services/elevenLabsService.js for
# speech-to-text (Scribe) transcription of uploaded audio.
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# --- Firebase Admin (Firestore + Cloud Storage) ---
# The server authenticates to Firebase using a service-account key file.
# Download it from the Firebase console:
#   Project settings -> Service accounts -> Generate new private key
# Save it as server/serviceAccountKey.json (this path is gitignored).
#
# The Cloud Storage bucket is currently hard-coded in
# services/firebaseService.js. If you fork this project, update the
# storageBucket value there to match your own Firebase project, e.g.
#   <your-project-id>.firebasestorage.app
